<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    tools:context=".MainActivity">

    <!-- HEADER: Logo y Notificación -->
    <ImageView
        android:id="@+id/ivLogoHeader"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginTop="20dp"
        android:layout_marginStart="20dp"
        android:src="@drawable/logoappmovil"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SafeWalk"
        android:textColor="@color/white"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginStart="10dp"
        app:layout_constraintBottom_toBottomOf="@id/ivLogoHeader"
        app:layout_constraintStart_toEndOf="@id/ivLogoHeader"
        app:layout_constraintTop_toTopOf="@id/ivLogoHeader" />

    <ImageView
        android:id="@+id/ivNotification"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_marginEnd="20dp"
        android:src="@android:drawable/ic_popup_reminder"
        app:layout_constraintBottom_toBottomOf="@id/ivLogoHeader"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/ivLogoHeader"
        app:tint="@color/white" />

    <!-- SALUDO -->
    <TextView
        android:id="@+id/tvUser"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Hola, Carlos Jose"
        android:textColor="@color/white"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginTop="30dp"
        android:layout_marginStart="20dp"
        app:layout_constraintTop_toBottomOf="@id/ivLogoHeader"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tvSub"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Camina seguro, llega tranquilo."
        android:textColor="@color/gray_text"
        app:layout_constraintTop_toBottomOf="@id/tvUser"
        app:layout_constraintStart_toStartOf="@id/tvUser" />

    <!-- TARJETA TU SEGURIDAD HOY -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardStatus"
        android:layout_width="220dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        app:cardBackgroundColor="@color/card_surface"
        app:cardCornerRadius="24dp"
        app:layout_constraintTop_toBottomOf="@id/tvSub"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Tu seguridad hoy" android:textColor="@color/white" android:textStyle="bold"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="15dp" android:gravity="center_vertical">
                <ImageView android:layout_width="18dp" android:layout_height="18dp" android:src="@android:drawable/ic_menu_manage" app:tint="@color/grad_green_start" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ruta segura: 85%" android:textColor="@color/gray_text" android:layout_marginStart="10dp" android:textSize="12sp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="10dp" android:gravity="center_vertical">
                <ImageView android:layout_width="18dp" android:layout_height="18dp" android:src="@android:drawable/ic_dialog_alert" app:tint="@color/grad_red_start" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Zonas de riesgo: 3" android:textColor="@color/gray_text" android:layout_marginStart="10dp" android:textSize="12sp"/>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ACCIONES RÁPIDAS -->
    <TextView
        android:id="@+id/tvAccionesLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Acciones rápidas"
        android:textColor="@color/white"
        android:textStyle="bold"
        android:layout_marginTop="30dp"
        android:layout_marginStart="20dp"
        app:layout_constraintTop_toBottomOf="@id/cardStatus"
        app:layout_constraintStart_toStartOf="parent" />

    <GridLayout
        android:id="@+id/gridActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="2"
        android:padding="12dp"
        app:layout_constraintTop_toBottomOf="@id/tvAccionesLabel">

        <!-- Botón 1: Navegación -->
        <androidx.cardview.widget.CardView
            android:id="@+id/btnNav"
            android:layout_width="0dp"
            android:layout_height="100dp"
            android:layout_columnWeight="1"
            android:layout_margin="8dp"
            app:cardCornerRadius="20dp"
            android:clickable="true"
            android:focusable="true">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/btn_green"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:padding="12dp">
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_directions" app:tint="@color/white"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Iniciar navegación\nRuta segura" android:textColor="@color/white" android:textSize="11sp" android:textStyle="bold" android:layout_marginTop="8dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Botón 2: SOS -->
        <androidx.cardview.widget.CardView
            android:id="@+id/btnSOSManual"
            android:layout_width="0dp"
            android:layout_height="100dp"
            android:layout_columnWeight="1"
            android:layout_margin="8dp"
            app:cardCornerRadius="20dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/btn_red"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:padding="12dp">
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_call" app:tint="@color/white"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Botón de\nemergencia" android:textColor="@color/white" android:textSize="11sp" android:textStyle="bold" android:layout_marginTop="8dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Botón 3: Contactos -->
        <androidx.cardview.widget.CardView
            android:id="@+id/btnContactos"
            android:layout_width="0dp"
            android:layout_height="100dp"
            android:layout_columnWeight="1"
            android:layout_margin="8dp"
            app:cardCornerRadius="20dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/btn_blue"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:padding="12dp">
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_myplaces" app:tint="@color/white"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Contactos de\nconfianza" android:textColor="@color/white" android:textSize="11sp" android:textStyle="bold" android:layout_marginTop="8dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Botón 4: Reportar -->
        <androidx.cardview.widget.CardView
            android:id="@+id/btnReportar"
            android:layout_width="0dp"
            android:layout_height="100dp"
            android:layout_columnWeight="1"
            android:layout_margin="8dp"
            app:cardCornerRadius="20dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/btn_purple"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:padding="12dp">
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/stat_notify_chat" app:tint="@color/white"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Reportar\nincidente" android:textColor="@color/white" android:textSize="11sp" android:textStyle="bold" android:layout_marginTop="8dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </GridLayout>

    <!-- BARRA DE NAVEGACIÓN INFERIOR -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="80dp"
        app:cardBackgroundColor="@color/card_surface"
        app:cardElevation="10dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center">

            <LinearLayout android:id="@+id/navInicio" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_today" app:tint="@color/accent_blue"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Inicio" android:textColor="@color/accent_blue" android:textSize="10sp"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/navZonas" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_dialog_alert" app:tint="@color/gray_text"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Zonas" android:textColor="@color/gray_text" android:textSize="10sp"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/navMapa" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_mylocation" app:tint="@color/gray_text"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mapa" android:textColor="@color/gray_text" android:textSize="10sp"/>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>